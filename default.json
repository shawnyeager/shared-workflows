{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Shared Renovate preset for shawnyeager workspace repos. Repos extend this via `extends: [\"github>shawnyeager/shared-workflows\"]`.",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":disableDependencyDashboard"
  ],
  "schedule": ["before 6am on monday"],
  "timezone": "UTC",
  "baseBranches": ["$default"],
  "major": {
    "enabled": false
  },
  "lockFileMaintenance": {
    "enabled": false
  },
  "stabilityDays": 3,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },
  "commitMessagePrefix": "chore(deps):",
  "packageRules": [
    {
      "description": "Group all dev dependencies into a single weekly PR per repo.",
      "matchDepTypes": ["devDependencies"],
      "groupName": "dev-dependencies"
    }
  ]
}
